# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3x-ui Panel Connection
XUI_HOST=your.server.com
XUI_PORT=2053
XUI_WEBBASEPATH=/
XUI_USERNAME=admin
XUI_PASSWORD=admin

# Comma-separated list of inbound IDs to provision clients in
# Find these in 3x-ui panel → Inbounds → ID column
XUI_INBOUND_IDS=1

# Comma-separated Telegram user IDs allowed to use the bot
# Use * to allow everyone (not recommended)
# Leave empty to deny all (secure default)
ALLOWED_TELEGRAM_IDS=

# Comma-separated Telegram user IDs blocked from using the bot
# Leave empty to block no one (secure default)
BLOCKED_TELEGRAM_IDS=

# VLESS flow control (optional)
# Recommended: xtls-rprx-vision (required for VLESS + Reality/XTLS over TCP)
# Applied only for VLESS inbounds with TCP transport; ignored for ws/grpc/kcp
# Leave empty if unsure
VLESS_FLOW=xtls-rprx-vision

# Subscription URL base (optional)
# Example: https://your.server.com:2096/sub
# If not set, bot will only send direct connection links
SUB_URL_BASE=
